rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /folders/{folder} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'malilens@mali.com';
    }
    match /photos/{photo} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'malilens@mali.com';
    }
    // Portfolio contact form — public write, no read
    match /messages/{message} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
